---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Nahj Journal — Nahj Institute</title>
    <meta name="description" content="The Nahj Journal is a peer-reviewed, open-access academic publication of Nahj Institute, appearing twice yearly across Islamic studies, political theory, philosophy, and the social sciences." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,600&family=Crimson+Pro:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Amiri:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet" />

    <style>
      :root {
        --navy:       #0C1B2E;
        --teal:       #1B5E6F;
        --gold:       #C8A252;
        --gold-light: #E2BC75;
        --cream:      #F7F2E8;
        --cream-dark: #EDE6D5;
        --charcoal:   #2B2B2B;
        --muted:      #6B6B6B;
        --white:      #FFFFFF;
      }

      * { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        background-color: var(--cream);
        color: var(--charcoal);
        font-family: 'Crimson Pro', Georgia, serif;
        font-size: 18px;
        line-height: 1.75;
        -webkit-font-smoothing: antialiased;
      }

      .container { max-width: 1120px; margin: 0 auto; padding: 0 2rem; }
      .container--narrow { max-width: 760px; margin: 0 auto; padding: 0 2rem; }

      .section-label {
        font-family: 'Crimson Pro', serif;
        font-size: 0.78rem;
        font-weight: 600;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--gold);
        display: block;
      }

      .divider-gold { width: 3.5rem; height: 2px; background: var(--gold); margin: 0.9rem 0 1.5rem; }
      .divider-gold.center { margin: 0.9rem auto 1.5rem; }

      /* ─── JOURNAL HERO ────────────────────────────────────── */
      .journal-hero {
        background: var(--navy);
        padding: 6rem 2rem 5rem;
        position: relative;
        overflow: hidden;
        border-bottom: 1px solid rgba(255,255,255,0.06);
      }

      .journal-hero::before {
        content: 'نهج';
        font-family: 'Amiri', serif;
        font-size: clamp(12rem, 24vw, 22rem);
        font-weight: 700;
        color: rgba(255,255,255,0.032);
        position: absolute;
        right: -1.5rem;
        top: 50%;
        transform: translateY(-50%);
        line-height: 1;
        pointer-events: none;
        user-select: none;
      }

      .journal-hero-inner {
        max-width: 1120px;
        margin: 0 auto;
        position: relative;
        z-index: 1;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 6rem;
        align-items: end;
      }

      .breadcrumb {
        font-size: 0.82rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: rgba(255,255,255,0.35);
        margin-bottom: 2.5rem;
        display: flex;
        align-items: center;
        gap: 0.6rem;
      }

      .breadcrumb a { color: rgba(255,255,255,0.35); text-decoration: none; transition: color 0.2s; }
      .breadcrumb a:hover { color: var(--gold); }
      .breadcrumb span { color: rgba(255,255,255,0.15); }

      .journal-wordmark {
        margin-bottom: 1.25rem;
      }

      .journal-wordmark .jw-label {
        font-family: 'Crimson Pro', serif;
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.28em;
        text-transform: uppercase;
        color: var(--gold);
        display: block;
        margin-bottom: 0.5rem;
      }

      .journal-wordmark h1 {
        font-family: 'Cormorant Garamond', serif;
        font-size: clamp(2.8rem, 5vw, 4.4rem);
        font-weight: 600;
        color: var(--white);
        line-height: 1.05;
        letter-spacing: -0.01em;
      }

      .journal-wordmark h1 em {
        font-style: italic;
        color: var(--gold-light);
      }

      .journal-wordmark .jw-sub {
        font-family: 'Cormorant Garamond', serif;
        font-size: 1rem;
        font-weight: 300;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: rgba(255,255,255,0.35);
        margin-top: 0.75rem;
        display: block;
      }

      .journal-hero-desc {
        font-size: 1.08rem;
        color: rgba(255,255,255,0.62);
        line-height: 1.85;
        font-weight: 300;
        margin-bottom: 1.5rem;
      }

      .journal-spec-table {
        display: flex;
        flex-direction: column;
        gap: 0;
        border-top: 1px solid rgba(255,255,255,0.08);
        margin-top: 1.5rem;
      }

      .jspec-row {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        padding: 0.75rem 0;
        border-bottom: 1px solid rgba(255,255,255,0.06);
        gap: 1rem;
      }

      .jspec-key {
        font-size: 0.75rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: rgba(255,255,255,0.3);
        flex-shrink: 0;
      }

      .jspec-val {
        font-family: 'Cormorant Garamond', serif;
        font-size: 1rem;
        font-weight: 500;
        color: var(--gold-light);
        text-align: right;
      }

      /* ─── CURRENT ISSUE BANNER ────────────────────────────── */
      .section-current {
        background: var(--cream-dark);
        padding: 5rem 2rem;
        border-bottom: 1px solid var(--cream-dark);
      }

      .current-layout {
        max-width: 1120px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1fr 2fr;
        gap: 5rem;
        align-items: start;
      }

      .current-label-col {
        position: sticky;
        top: 4rem;
        padding-top: 0.2rem;
      }

      .current-label-col h2 {
        font-family: 'Cormorant Garamond', serif;
        font-size: 2.4rem;
        font-weight: 600;
        color: var(--navy);
        line-height: 1.1;
        margin-top: 0.5rem;
        margin-bottom: 1.5rem;
      }

      .issue-vol-badge {
        display: inline-block;
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--navy);
        border: 1px solid var(--gold);
        padding: 0.4rem 0.9rem;
        margin-bottom: 1.5rem;
      }

      .btn-primary {
        display: inline-block;
        background: var(--gold);
        color: var(--navy);
        font-family: 'Crimson Pro', serif;
        font-size: 0.88rem;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        padding: 0.85rem 2rem;
        text-decoration: none;
        transition: background 0.2s, transform 0.15s;
      }

      .btn-primary:hover { background: var(--gold-light); transform: translateY(-1px); }

      .btn-outline-dark {
        display: inline-block;
        border: 1px solid var(--navy);
        color: var(--navy);
        font-family: 'Crimson Pro', serif;
        font-size: 0.88rem;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        padding: 0.85rem 2rem;
        text-decoration: none;
        transition: background 0.2s, color 0.2s, transform 0.15s;
      }

      .btn-outline-dark:hover { background: var(--navy); color: var(--gold); transform: translateY(-1px); }

      .current-articles {
        display: flex;
        flex-direction: column;
        gap: 0;
        border-top: 1px solid var(--cream-dark);
      }

      .article-row {
        padding: 1.75rem 0;
        border-bottom: 1px solid var(--cream-dark);
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 1.5rem;
        align-items: start;
        text-decoration: none;
        color: inherit;
        transition: background 0.2s;
      }

      .article-row:hover { background: rgba(255,255,255,0.5); margin: 0 -1rem; padding-left: 1rem; padding-right: 1rem; }

      .article-row-num {
        font-family: 'Cormorant Garamond', serif;
        font-size: 0.88rem;
        font-weight: 600;
        color: var(--gold);
        padding-top: 0.2rem;
        min-width: 1.5rem;
      }

      .article-row-tag {
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--teal);
        margin-bottom: 0.4rem;
        display: block;
      }

      .article-row-title {
        font-family: 'Cormorant Garamond', serif;
        font-size: 1.3rem;
        font-weight: 600;
        color: var(--navy);
        line-height: 1.22;
        margin-bottom: 0.35rem;
      }

      .article-row-author {
        font-size: 0.85rem;
        color: var(--muted);
      }

      /* ─── ABOUT THE JOURNAL ───────────────────────────────── */
      .section-about-journal {
        padding: 5.5rem 2rem;
        background: var(--cream);
      }

      .about-journal-layout {
        max-width: 1120px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 6rem;
        align-items: start;
      }

      .about-journal-text h2 {
        font-family: 'Cormorant Garamond', serif;
        font-size: clamp(1.9rem, 3.5vw, 2.8rem);
        font-weight: 600;
        color: var(--navy);
        line-height: 1.1;
        margin-top: 0.5rem;
        margin-bottom: 1.5rem;
      }

      .about-journal-text p {
        font-size: 1.05rem;
        color: var(--charcoal);
        line-height: 1.88;
        font-weight: 300;
        margin-bottom: 1.25rem;
      }

      .about-journal-text p:last-child { margin-bottom: 0; }

      .scope-list {
        list-style: none;
        padding: 0;
        margin: 0;
        border-top: 1px solid var(--cream-dark);
      }

      .scope-list li {
        padding: 0.9rem 0;
        border-bottom: 1px solid var(--cream-dark);
        font-size: 1rem;
        color: var(--charcoal);
        display: flex;
        align-items: baseline;
        gap: 0.75rem;
      }

      .scope-list li::before {
        content: '◆';
        font-size: 0.38rem;
        color: var(--gold);
        flex-shrink: 0;
      }

      /* ─── EDITORIAL BOARD ─────────────────────────────────── */
      .section-board {
        background: var(--navy);
        padding: 5.5rem 2rem;
        position: relative;
        overflow: hidden;
      }

      .section-board::before {
        content: '';
        position: absolute;
        inset: 0;
        background: radial-gradient(ellipse 50% 70% at 85% 40%, rgba(27,94,111,0.3) 0%, transparent 65%);
        pointer-events: none;
      }

      .board-inner {
        max-width: 1120px;
        margin: 0 auto;
        position: relative;
        z-index: 1;
      }

      .board-header { margin-bottom: 3.5rem; }

      .board-header h2 {
        font-family: 'Cormorant Garamond', serif;
        font-size: clamp(1.9rem, 3.5vw, 2.8rem);
        font-weight: 600;
        color: var(--white);
        margin-top: 0.5rem;
        max-width: 560px;
        line-height: 1.1;
      }

      .board-header p {
        font-size: 1rem;
        color: rgba(255,255,255,0.52);
        font-weight: 300;
        line-height: 1.8;
        max-width: 560px;
        margin-top: 0.75rem;
      }

      .board-roles {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 0;
      }

      .board-role {
        padding: 2rem 1.75rem;
        border: 1px solid rgba(255,255,255,0.07);
        transition: background 0.2s;
      }

      .board-role:hover { background: rgba(255,255,255,0.03); }

      .board-role-label {
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--gold);
        display: block;
        margin-bottom: 1rem;
      }

      .board-role-name {
        font-family: 'Cormorant Garamond', serif;
        font-size: 1.25rem;
        font-weight: 600;
        color: var(--white);
        margin-bottom: 0.25rem;
      }

      .board-role-affil {
        font-size: 0.88rem;
        color: rgba(255,255,255,0.42);
        line-height: 1.5;
      }

      .board-note {
        margin-top: 2.5rem;
        font-size: 0.92rem;
        color: rgba(255,255,255,0.32);
        font-style: italic;
        font-weight: 300;
      }

      /* ─── ARCHIVE ─────────────────────────────────────────── */
      .section-archive {
        padding: 5.5rem 2rem;
        background: var(--cream-dark);
      }

      .archive-header { margin-bottom: 3rem; }

      .archive-header h2 {
        font-family: 'Cormorant Garamond', serif;
        font-size: clamp(1.9rem, 3.5vw, 2.8rem);
        font-weight: 600;
        color: var(--navy);
        margin-top: 0.5rem;
      }

      .archive-list {
        max-width: 1120px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        gap: 0;
        border-top: 1px solid var(--cream-dark);
      }

      .archive-row {
        display: grid;
        grid-template-columns: 200px 1fr auto;
        gap: 3rem;
        align-items: center;
        padding: 1.75rem 0;
        border-bottom: 1px solid var(--cream-dark);
        text-decoration: none;
        color: inherit;
        transition: background 0.2s;
      }

      .archive-row:hover { background: var(--white); margin: 0 -2rem; padding-left: 2rem; padding-right: 2rem; }

      .archive-vol {
        font-family: 'Cormorant Garamond', serif;
        font-size: 1rem;
        font-weight: 600;
        color: var(--navy);
      }

      .archive-theme {
        font-family: 'Cormorant Garamond', serif;
        font-size: 1.2rem;
        font-weight: 400;
        font-style: italic;
        color: var(--charcoal);
      }

      .archive-count {
        font-size: 0.82rem;
        color: var(--muted);
        text-align: right;
        white-space: nowrap;
      }

      .archive-badge {
        display: inline-block;
        font-size: 0.68rem;
        font-weight: 600;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        padding: 0.25rem 0.6rem;
        border: 1px solid var(--gold);
        color: var(--gold);
        margin-left: 0.75rem;
      }

      .archive-row.forthcoming { opacity: 0.5; cursor: default; }

      /* ─── SUBMIT CTA ──────────────────────────────────────── */
      .section-submit-cta {
        background: var(--cream);
        padding: 5rem 2rem;
        text-align: center;
        border-top: 1px solid var(--cream-dark);
      }

      .section-submit-cta h2 {
        font-family: 'Cormorant Garamond', serif;
        font-size: clamp(1.8rem, 3.5vw, 2.6rem);
        font-weight: 600;
        color: var(--navy);
        margin-top: 0.5rem;
        margin-bottom: 1rem;
        line-height: 1.15;
      }

      .section-submit-cta p {
        font-size: 1.05rem;
        color: var(--muted);
        max-width: 520px;
        margin: 0 auto 2.25rem;
        font-weight: 300;
        line-height: 1.8;
      }

      .cta-buttons { display: flex; justify-content: center; gap: 1rem; flex-wrap: wrap; }

      /* ─── RESPONSIVE ──────────────────────────────────────── */
      @media (max-width: 900px) {
        .journal-hero-inner { grid-template-columns: 1fr; gap: 3rem; }
        .current-layout { grid-template-columns: 1fr; gap: 2.5rem; }
        .current-label-col { position: static; }
        .about-journal-layout { grid-template-columns: 1fr; gap: 3rem; }
        .archive-row { grid-template-columns: 1fr 1fr; gap: 1.5rem; }
        .archive-theme { grid-column: span 2; }
      }

      @media (max-width: 768px) {
        .journal-hero { padding: 4rem 1.5rem 3rem; }
        .journal-hero::before { font-size: 8rem; }
        .archive-row { grid-template-columns: 1fr; gap: 0.5rem; }
        .archive-row:hover { margin: 0; padding: 1.75rem 0; }
      }
    </style>
  </head>

  <body>
    <Header />

    <!-- ═══════════════════════════════════════════ JOURNAL HERO -->
    <section class="journal-hero">
      <div class="journal-hero-inner">
        <div>
          <nav class="breadcrumb">
            <a href="/Nahj-Institute/">Home</a>
            <span>/</span>
            <span style="color: rgba(255,255,255,0.6);">Nahj Journal</span>
          </nav>

          <div class="journal-wordmark">
            <span class="jw-label">A Publication of Nahj Institute</span>
            <h1>The <em>Nahj</em><br />Journal</h1>
            <span class="jw-sub">Peer-Reviewed · Open Access · Twice Yearly</span>
          </div>
        </div>

        <div>
          <p class="journal-hero-desc">
            The Nahj Journal publishes original research in Islamic studies, political theory, philosophy, and the social sciences. It is addressed to academic readers and holds all submissions to double-blind peer review. All content is freely available online.
          </p>

          <div class="journal-spec-table">
            <div class="jspec-row">
              <span class="jspec-key">ISSN</span>
              <span class="jspec-val">Forthcoming</span>
            </div>
            <div class="jspec-row">
              <span class="jspec-key">Frequency</span>
              <span class="jspec-val">Spring and Autumn</span>
            </div>
            <div class="jspec-row">
              <span class="jspec-key">Review Process</span>
              <span class="jspec-val">Double-blind peer review</span>
            </div>
            <div class="jspec-row">
              <span class="jspec-key">Access</span>
              <span class="jspec-val">Open access, no fees</span>
            </div>
            <div class="jspec-row">
              <span class="jspec-key">Publisher</span>
              <span class="jspec-val">Nahj Institute</span>
            </div>
            <div class="jspec-row">
              <span class="jspec-key">Launched</span>
              <span class="jspec-val">Spring 2025</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <main>

      <!-- ══════════════════════════════════════ CURRENT ISSUE -->
      <section class="section-current">
        <div class="current-layout">
          <div class="current-label-col">
            <span class="section-label">Now Available</span>
            <div class="divider-gold"></div>
            <h2>Volume 1, Issue 1</h2>
            <div class="issue-vol-badge">Spring 2025</div>
            <p style="font-size: 1rem; color: var(--muted); font-weight: 300; line-height: 1.8; margin-bottom: 1.5rem;">
              The inaugural issue takes up the theme of authority and legitimacy in the contemporary Muslim world, gathering seven original articles and a review essay.
            </p>
            <div style="display: flex; flex-direction: column; gap: 0.75rem;">
              <a href="#" class="btn-primary">Read This Issue</a>
              <a href="/contact#submissions" class="btn-outline-dark">Submit to Vol. 1, No. 2</a>
            </div>
          </div>

          <div>
            <div class="current-articles">
              <a href="#" class="article-row">
                <span class="article-row-num">01</span>
                <div>
                  <span class="article-row-tag">Theology & Politics</span>
                  <div class="article-row-title">The Imamate and the Modern State: Authority, Legitimacy, and the Crisis of Governance in Contemporary Shia Political Thought</div>
                  <div class="article-row-author">Dr. Ali Haider Naqvi</div>
                </div>
              </a>

              <a href="#" class="article-row">
                <span class="article-row-num">02</span>
                <div>
                  <span class="article-row-tag">Religious Harmony</span>
                  <div class="article-row-title">Dialogue as Method: Toward a Theology of Encounter in Pluralist Societies</div>
                  <div class="article-row-author">Sara Kazemi</div>
                </div>
              </a>

              <a href="#" class="article-row">
                <span class="article-row-num">03</span>
                <div>
                  <span class="article-row-tag">Science & Ethics</span>
                  <div class="article-row-title">Artificial Intelligence and the Question of Moral Agency: Notes Toward an Islamic Bioethics</div>
                  <div class="article-row-author">Dr. Hina Raza</div>
                </div>
              </a>

              <a href="#" class="article-row">
                <span class="article-row-num">04</span>
                <div>
                  <span class="article-row-tag">Philosophy</span>
                  <div class="article-row-title">Reason and Revelation in the Mutazilite Tradition: A Reconsideration</div>
                  <div class="article-row-author">Prof. Hassan al-Amin</div>
                </div>
              </a>

              <a href="#" class="article-row">
                <span class="article-row-num">05</span>
                <div>
                  <span class="article-row-tag">Political Theory</span>
                  <div class="article-row-title">Sovereignty, Shura, and the Constitutional State: Three Models of Islamic Governance</div>
                  <div class="article-row-author">Maryam Hosseini</div>
                </div>
              </a>

              <a href="#" class="article-row">
                <span class="article-row-num">06</span>
                <div>
                  <span class="article-row-tag">Social Science</span>
                  <div class="article-row-title">Sectarianism as a Sociological Category: Limits and Possibilities</div>
                  <div class="article-row-author">Dr. Zainab Mirza</div>
                </div>
              </a>

              <a href="#" class="article-row">
                <span class="article-row-num">07</span>
                <div>
                  <span class="article-row-tag">Review Essay</span>
                  <div class="article-row-title">On Recent Scholarship in Islamic Political Thought: A Critical Survey, 2020 to 2025</div>
                  <div class="article-row-author">Editorial Team, Nahj Institute</div>
                </div>
              </a>
            </div>
          </div>
        </div>
      </section>

      <!-- ═══════════════════════════════════ ABOUT THE JOURNAL -->
      <section class="section-about-journal">
        <div class="about-journal-layout">
          <div class="about-journal-text">
            <span class="section-label">Aims and Scope</span>
            <div class="divider-gold"></div>
            <h2>What the Journal Publishes</h2>
            <p>
              The Nahj Journal publishes original research articles, review essays, and critical responses. It does not have a fixed disciplinary home. The journal is defined instead by a set of questions: about Islamic thought and its intellectual heritage, about the place of Muslim communities and states in the contemporary world, and about the relationship between religious tradition and modern life in its political, social, scientific, and ethical dimensions.
            </p>
            <p>
              The journal welcomes work that is methodologically rigorous and engages seriously with existing scholarship. It does not publish polemical writing, and it is not a forum for advocacy. The standard applied to all submissions is that of a serious peer-reviewed humanities and social sciences journal.
            </p>
          </div>

          <div>
            <span class="section-label">Areas of Interest</span>
            <div class="divider-gold"></div>
            <ul class="scope-list">
